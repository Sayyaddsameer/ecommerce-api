# Application
NODE_ENV=development
PORT=8080

# PostgreSQL connection (used by knexfile.js)
DATABASE_URL=postgres://ecommerce:ecommerce_pw@db:5432/ecommerce
PGHOST=db
PGPORT=5432
PGUSER=ecommerce
PGPASSWORD=ecommerce_pw
PGDATABASE=ecommerce

# Redis (used by BullMQ for the reservation-expiration queue)
REDIS_URL=redis://redis:6379

# Cart reservation window, in minutes
RESERVATION_TTL_MINUTES=15

# How often the background worker sweeps for expired reservations, in seconds
EXPIRATION_SWEEP_INTERVAL_SECONDS=60
