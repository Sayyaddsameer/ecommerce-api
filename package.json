{
  "name": "ecommerce-inventory-pricing-api",
  "version": "1.0.0",
  "description": "REST API for e-commerce inventory tracking, dynamic pricing, and cart reservation with race-condition-safe concurrency control.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "worker": "node src/worker.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --runInBand --watch"
  },
  "keywords": ["ecommerce", "inventory", "pricing", "rest-api"],
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
